# Copy to .env and fill in. Keep .env readable only by the service user:
#   chmod 600 .env

# REQUIRED: shared secret the Android app must send. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
PHOTOSYNC_TOKEN=replace-with-a-long-random-token

# Where photos/videos are stored. Per-device folders are created underneath.
PHOTOSYNC_DATA_DIR=/data/photos

# uvicorn bind address. Keep on localhost; the reverse proxy forwards to it.
PHOTOSYNC_HOST=127.0.0.1
PHOTOSYNC_PORT=8080

# Path prefix when served behind the reverse proxy (matches the proxy route).
PHOTOSYNC_ROOT_PATH=/photos

# Max single upload (bytes). Default 8 GiB. Set 0 to disable the cap.
PHOTOSYNC_MAX_UPLOAD_BYTES=8589934592

# Permissions for created folders / files (octal). Spec requires 777 folders.
PHOTOSYNC_DIR_MODE=777
PHOTOSYNC_FILE_MODE=644
